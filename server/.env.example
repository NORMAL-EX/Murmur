# ---- Murmur server configuration ----

# HTTP port
PORT=8080

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-this-to-a-long-random-secret

# Super admin seeded on first boot (skipped if the account already exists).
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=admin12345

# SQLite database file (directory is created automatically).
DB_PATH=./data/murmur.db

# Directory for uploaded avatars (served at /uploads).
UPLOAD_DIR=./uploads

# Optional: dedicated key to encrypt secret settings (e.g. the AI API key).
# Defaults to a value derived from JWT_SECRET when unset.
# SETTINGS_ENC_KEY=

# Optional: path to the built frontend to serve (defaults to ../web/dist or ./web/dist).
# STATIC_DIR=../web/dist
